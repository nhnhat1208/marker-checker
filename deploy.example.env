# deploy.env — runtime environment variables for AgentBase deployment
# Copy this file to deploy.env and fill in the actual values.
# deploy.env is gitignored — do NOT commit it.
#
# Usage:
#   bash .claude/skills/agentbase/scripts/runtime.sh update <RUNTIME_ID> \
#     --image <IMAGE> --flavor <FLAVOR> --from-cr --env-file deploy.env

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_ENABLED=true
TELEGRAM_POLLING_ENABLED=true
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>

# ── Google Sheets ─────────────────────────────────────────────────────────────
GOOGLE_SHEETS_ENABLED=true
GOOGLE_SHEETS_SPREADSHEET_ID=<your-spreadsheet-id>
# Base64-encoded service account JSON (mutually exclusive with file path below)
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=<base64-encoded-service-account-json>
# Alternative: path to the service account JSON file inside the container
# GOOGLE_SERVICE_ACCOUNT_FILE=/run/secrets/google-sa.json
GOOGLE_SHEETS_AUTO_CREATE_WORKSHEETS=true

# ── AI (LLM) ──────────────────────────────────────────────────────────────────
AI_ENABLED=true
AI_PROMPT_VERSION=request-parse-v1
AI_MODEL=minimax/minimax-m2.5
AI_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
AI_API_KEY=<your-ai-api-key>
AI_TIMEOUT_SECONDS=30
AI_MAX_TOKENS=1500
AI_TEMPERATURE=0.0
AI_TOP_P=0.95
AI_PRESENCE_PENALTY=0.0
