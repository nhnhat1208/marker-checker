# deploy.env — deployment config + runtime environment variables for AgentBase
# Copy this file to deploy.env and fill in the actual values.
# deploy.env is gitignored — do NOT commit it.
#
# Usage:
#   make deploy                              # build + push + update runtime
#   bash .claude/skills/agentbase/scripts/runtime.sh update <RUNTIME_ID> \
#     --image <IMAGE> --flavor <FLAVOR> --from-cr --env-file deploy.env

# ── Deployment config (used by Makefile) ──────────────────────────────────────
# Not secrets — they identify where to push images and which runtime to update.
IMAGE_REPO=vcr.vngcloud.vn/<project-id>/<image-name>
RUNTIME_ID=runtime-<uuid>
FLAVOR=runtime-s2-general-2x4

# ── Telegram ──────────────────────────────────────────────────────────────────
# Telegram mode (webhook | polling) is set in runtime.yaml — not here.
# TELEGRAM_WEBHOOK_URL: explicit public URL for Telegram to call. Required because
# GREENNODE_ENDPOINT_URL is the internal invocation URL, not the public endpoint URL.
# Find the public URL in AgentBase console → Runtime → Endpoints → DEFAULT → URL.
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>
TELEGRAM_WEBHOOK_URL=<public-endpoint-url>/telegram-webhook

# ── Google Sheets (only needed when persistence.backend: google_sheets) ───────
GOOGLE_SHEETS_SPREADSHEET_ID=<your-spreadsheet-id>
# Base64-encoded service account JSON (mutually exclusive with file path below)
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=<base64-encoded-service-account-json>
# Alternative: path to the service account JSON file inside the container
# GOOGLE_SERVICE_ACCOUNT_FILE=/run/secrets/google-sa.json
GOOGLE_SHEETS_AUTO_CREATE_WORKSHEETS=true

# ── AI (LLM) ──────────────────────────────────────────────────────────────────
AI_ENABLED=true
AI_PROMPT_VERSION=request-parse-v1
AI_MODEL=minimax/minimax-m2.5
AI_BASE_URL=<your-base-api-url>
AI_API_KEY=<your-ai-api-key>
AI_TIMEOUT_SECONDS=30
AI_MAX_TOKENS=1500
AI_TEMPERATURE=0.0
AI_TOP_P=0.95
AI_PRESENCE_PENALTY=0.0

# ── PostgreSQL (Neon) ─────────────────────────────────────────────────────────
# Required when persistence_backend: postgres (set in runtime.yaml)
POSTGRES_DSN=postgresql://<user>:<password>@<host>/<db>?sslmode=require

# ── Web UI (Google OAuth) ──────────────────────────────────────────────────────
# Web UI is enabled automatically when GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET are both set.
# Add http://localhost:8080/auth/callback (dev) and https://<public-url>/auth/callback (prod)
# to the Authorized redirect URIs list in Google Cloud Console.
GOOGLE_CLIENT_ID=<your-google-oauth-client-id>
GOOGLE_CLIENT_SECRET=<your-google-oauth-client-secret>
GOOGLE_SESSION_SECRET=<random-secret-for-signing-session-cookies>
# GOOGLE_REDIRECT_URI=https://<public-endpoint>/auth/callback  # auto-derived if empty

# ── Memory Service (AgentBase) — optional ─────────────────────────────────────
# Set MEMORY_MEMORY_ID to enable. Strategy IDs are optional (enables per-user
# preference and approver pattern learning if set).
# MEMORY_MEMORY_ID=<your-memory-id>
# MEMORY_USER_PREF_STRATEGY_ID=<strategy-id>
# MEMORY_APPROVER_BEHAVIOR_STRATEGY_ID=<strategy-id>
